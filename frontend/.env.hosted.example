# Hosted MULTI-TENANT deployment (Vercel SSR + Railway backend + Supabase auth).
#
# This is the authenticated, per-user build — distinct from the read-only static
# snapshot documented in .env.production.example. Set these at BUILD time on
# Vercel (NEXT_PUBLIC_* are inlined into the bundle). Do NOT also set
# NEXT_PUBLIC_STATIC_DATA or NEXT_PUBLIC_READONLY — those select the backend-free
# public snapshot instead.
#
# Local dev sets NONE of these: `next dev` + uvicorn (AUTH_ENABLED off) runs
# exactly as before, with no login gate and no token attached.

# The FastAPI backend base URL (Railway). No trailing slash.
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# Supabase project — the presence of BOTH of these turns auth ON in the frontend
# (proxy.ts login gate + a Bearer token attached to every backend call). Use the
# anon / publishable key ONLY; never the service-role key (it would ship to the
# browser). Must match the backend's SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=https://xsbyhxiwpwgauctpjjky.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
