# Read-only public deployment (e.g. Vercel).
#
# Copy the two vars below into the Vercel project's Environment Variables (or a
# local .env.production) to build the backend-free, read-only site. They must be
# set at BUILD time — Next.js inlines NEXT_PUBLIC_* into the client bundle.
#
# Local development sets NEITHER of these: `next dev` + uvicorn behaves exactly
# as before, with all edit / predict / queue write flows enabled.

# Serve data from the static snapshots in public/data/ instead of the FastAPI
# backend. Produce/refresh those files with `npm run export-data`.
NEXT_PUBLIC_STATIC_DATA=1

# Hide every write/mutation affordance and hard-fail write endpoints. Also makes
# /predict, /add-book, /edit-ratings render a read-only notice.
NEXT_PUBLIC_READONLY=1

# NEXT_PUBLIC_API_URL is intentionally unused when NEXT_PUBLIC_STATIC_DATA=1.
# (In dynamic/local mode it defaults to http://localhost:8000.)
